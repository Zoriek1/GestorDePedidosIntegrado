# Docker Compose - Variáveis de ambiente
# Copie para .env na raiz do repositório

# POSTGRES (obrigatório)
POSTGRES_USER=gestor
POSTGRES_PASSWORD=defina_senha_forte_aqui
POSTGRES_DB=gestor_pedidos

# Backend
SECRET_KEY=gerar-com-python-c-import-secrets-print-secrets-token-hex-32
ADMIN_PASSWORD=senha_forte_aqui

# Proxy (quando usar HTTPS)
USE_HTTPS=false

# Nuvemshop (para integração e puxar pedidos; ver backend/docs/NUVEMSHOP_CREDENTIALS.md)
# Na VPS, NUVEMSHOP_PUBLIC_BASE_URL deve ser a URL pública (ex.: https://gestaopedidos.planteumaflor.online)
#NUVEMSHOP_APP_ID=
#NUVEMSHOP_CLIENT_SECRET=
#NUVEMSHOP_USER_AGENT=Gestor Pedidos (contato@seudominio.com)
#NUVEMSHOP_PUBLIC_BASE_URL=https://gestaopedidos.planteumaflor.online
