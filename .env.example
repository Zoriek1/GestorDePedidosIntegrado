# =============================================================
# Docker Compose + Backend + Frontend - Variáveis de ambiente
# Copie para .env na raiz do repositório e preencha os valores
# =============================================================

# --- Banco de dados (PostgreSQL) ---
POSTGRES_USER=gestor
POSTGRES_PASSWORD=defina_senha_forte_aqui
POSTGRES_DB=gestor_pedidos

# --- Backend ---
FLASK_ENV=production
APP_ENV=production
SECRET_KEY=gerar-com-python-c-import-secrets-print-secrets-token-hex-32
ADMIN_PASSWORD=senha_forte_aqui
HOST=0.0.0.0
PORT=5000
USE_HTTPS=false
ENABLE_DEBUG_ENDPOINTS=false

# --- Acompanhamento público do pedido (página /acompanhar/<token>) ---
# Base usada para montar o link enviado ao cliente. Se vazio, cai em
# NUVEMSHOP_PUBLIC_BASE_URL e depois no domínio padrão.
#PUBLIC_BASE_URL=https://gestaopedidos.planteumaflor.online
# Validade do token de acompanhamento, em dias (default 60). Links expirados → 404.
#TRACK_TOKEN_MAX_AGE_DAYS=60

# --- Google Sheets / Drive (exportar planilha de vendas e backup) ---
# Cole aqui o conteúdo do arquivo google_credentials.json em UMA ÚNICA LINHA (sem quebras)
# Como gerar: cat backend/user/config/google_credentials.json | tr -d '\n'
# Quando definido, o backend cria o arquivo automaticamente na inicialização do container
#GOOGLE_CREDENTIALS_JSON={"type":"service_account","project_id":"..."}
# Título da planilha Google Sheets só para export de leads (default: Leads_GESTOR)
#GOOGLE_SHEETS_LEADS_DOCUMENT_NAME=Leads_GESTOR

# --- Google Maps Platform (geocodificação, rotas e mapa embeddado) ---
GOOGLE_MAPS_API_KEY=sua_chave_aqui
VITE_GOOGLE_MAPS_API_KEY=sua_chave_aqui   # mesma chave, usada no build do frontend
# Build Docker do backend: 1 = usar docker/prebuilt-dist/ (CI ou ./deploy.sh); 0 = npm run build no Dockerfile
#USE_PREBUILT_DIST=0

# --- Nuvemshop (integração / puxar pedidos) ---
# Ver docs/integrations.md
#NUVEMSHOP_APP_ID=
#NUVEMSHOP_CLIENT_SECRET=
#NUVEMSHOP_USER_AGENT=Gestor Pedidos (contato@seudominio.com)
#NUVEMSHOP_PUBLIC_BASE_URL=https://gestaopedidos.planteumaflor.online

# --- Bling API v3 (OAuth + pedidos/financeiro) ---
# Nunca commitar Client Secret real. Regenerar antes da producao.
#BLING_ENABLED=false
#BLING_CLIENT_ID=
#BLING_CLIENT_SECRET=
#BLING_REDIRECT_URI=https://gestaopedidos.planteumaflor.online/api/integrations/bling/oauth/callback
#BLING_API_BASE_URL=https://api.bling.com.br/Api/v3
#BLING_AUTH_BASE_URL=https://www.bling.com.br/Api/v3/oauth
#BLING_TIMEOUT_SECONDS=20
#BLING_DEFAULT_PRODUCT_CODE=PEDIDO-FLORICULTURA
#BLING_STORE_ID=default

# --- Meta CAPI (eventos de compra) ---
# Em Docker Compose, use ESTE .env da raiz (não backend/.env).
META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
META_CAPI_API_VERSION=v21.0
# Opcional para homologação/debug:
#META_TEST_EVENT_CODE=
META_CAPI_USE_GATEWAY=false
META_CAPI_GATEWAY_DOMAIN=gestaopedidos.planteumaflor.online
# Opcional: endpoint completo sobrescrevendo domínio+versão
#META_CAPI_GATEWAY_ENDPOINT=

# Worker CAPI assíncrono (container capi-worker): envio do outbox em segundo plano.
# Intervalo do polling do outbox e backoff antes de retentar um envio que falhou (retryable).
#META_CAPI_WORKER_INTERVAL_SECONDS=5
#META_CAPI_RETRY_BACKOFF_SECONDS=300

# Funil leads (landing): Contact (clique WhatsApp) + Lead (telefone salvo)
# Quando true: POST /api/leads com event=whatsapp_click exige meta_event_id_contact (ou capi_event_id)
# alinhado ao Pixel; PATCH /api/leads/<id>/phone dispara Lead (value 15 BRL) com novo event_id.
#META_CAPI_LEAD_FUNNEL_ENABLED=false

# --- APIs de rota (opcionais, Google Maps é o primário) ---
#GRAPHHOPPER_API_KEY=
#OPENROUTE_API_KEY=

# --- Endereço da floricultura (ponto de origem das rotas e fallback CAPI para Retirada) ---
#ENDERECO_FLORICULTURA=Rua Exemplo, 123, Bairro, Goiânia, GO
#LOJA_CEP=74000000

# --- UTMify (API de pedidos — vendas checkout WhatsApp) ---
# Credencial: Integrações > Webhooks > Credenciais de API
#UTMIFY_ENABLED=false
#UTMIFY_API_TOKEN=
#UTMIFY_POSTBACK_URL=https://api.utmify.com.br/api-credentials/orders
#UTMIFY_PLATFORM=WhatsAppManual
#UTMIFY_TIMEOUT_SECONDS=5
#UTMIFY_IS_TEST=false

# --- Frontend ---
VITE_ENABLE_OFFLINE_DIAGNOSTICS=false

# --- Backup (opcional) ---
#GDRIVE_BACKUP_DIR=/var/backups/gestor-pedidos
#BACKUP_SECONDARY_DIR=
