# Frontend V2 Environment Variables
# Copy this file to .env and adjust values as needed

# API Configuration
# Base URL for API requests. In development, this is proxied by Vite.
# In production, this should be the full URL or relative path to the API.
# Default: /api
VITE_API_BASE_URL=/api

# Vite Dev Server Proxy Target
# Target URL for the Vite proxy when running in development mode.
# This is used by vite.config.ts to proxy /api requests to the backend.
# Default: http://localhost:5000
VITE_API_TARGET=http://localhost:5000

# Offline Diagnostics
# Enable offline diagnostics page for debugging offline functionality.
# Set to 'true' to enable, 'false' to disable.
# Default: false
VITE_ENABLE_OFFLINE_DIAGNOSTICS=false
