# Plante Uma Flor - Variáveis de Ambiente
# Copie este arquivo para .env e ajuste os valores conforme necessário
# IMPORTANTE: .env não deve ser versionado (está no .gitignore)

# ============================================
# SEGURANÇA
# ============================================

# Secret key para sessões Flask (obrigatório em produção)
# Gere uma chave segura: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=plante-uma-flor-pwa-secret-key-2024

# Senha do administrador (Basic Auth)
ADMIN_PASSWORD=plante1998

# Habilitar autenticação global (padrão: true)
ENABLE_AUTH=true

# Habilitar rate limiting (padrão: true)
ENABLE_RATE_LIMIT=true

# Habilitar endpoints de debug (padrão: false)
# ATENÇÃO: Desabilitar em produção
ENABLE_DEBUG_ENDPOINTS=false

# ============================================
# SERVIDOR
# ============================================

# Host do servidor (padrão: 0.0.0.0 - aceita conexões de qualquer IP)
HOST=0.0.0.0

# Porta do servidor (padrão: 5000)
PORT=5000

# Modo debug (padrão: false)
# ATENÇÃO: Desabilitar em produção
DEBUG=false

# Ambiente Flask (development, production, testing)
FLASK_ENV=development

# Ambiente da aplicação (alternativa a FLASK_ENV)
# APP_ENV=development

# Usar HTTPS (padrão: false)
USE_HTTPS=false

# Desabilitar reloader automático (padrão: false)
# Útil para estabilidade com múltiplos clientes
NO_RELOAD=false

# Forçar início mesmo se porta estiver em uso (padrão: false)
FORCE_START=false

# ============================================
# BANCO DE DADOS
# ============================================

# URI do banco de dados (padrão: SQLite em %USERPROFILE%/var/lib/database/database.db)
# SQLALCHEMY_DATABASE_URI=sqlite:///C:/Users/Usuario/var/lib/database/database.db

# Modo síncrono do SQLite (FULL, NORMAL, OFF)
# FULL = mais seguro, mais lento
# NORMAL = balanceado (recomendado)
# OFF = mais rápido, menos seguro
SQLITE_SYNCHRONOUS=FULL

# Permitir bootstrap automático do banco (padrão: false)
ALLOW_DB_BOOTSTRAP=false

# ============================================
# APIs EXTERNAS
# ============================================

# GraphHopper API Key (opcional)
# Obter em: https://www.graphhopper.com/api/
# Gratuito até 500 requisições/dia
GRAPHHOPPER_API_KEY=

# OpenRouteService API Key (opcional)
# Obter em: https://openrouteservice.org/dev/#/signup
# Gratuito até 2.000 requisições/dia
OPENROUTE_API_KEY=

# Endereço da floricultura (obrigatório para cálculo de distâncias)
# Formato: Rua, Número, Bairro, Cidade, Estado, CEP
# Exemplo: Rua Exemplo, 123, Bairro Centro, Goiânia, GO, 74000-000
ENDERECO_FLORICULTURA=

# ============================================
# BACKUP
# ============================================

# Diretório do Google Drive Desktop para backups encriptados
# Padrão: C:\Users\<USER>\Meu Drive\Plante Uma Flor Confidential\Database - Pedidos Gestor
# GDRIVE_BACKUP_DIR=C:\Users\Usuario\Meu Drive\Plante Uma Flor Confidential\Database - Pedidos Gestor

# ID da pasta do Google Drive para backups (opcional)
# GDRIVE_BACKUP_FOLDER_ID=

# ============================================
# GOOGLE SERVICES
# ============================================

# Caminho para credenciais do Google (opcional)
# Para exportação de planilhas para Google Sheets
# GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\credentials.json

# Caminho alternativo para credenciais do Google
# GOOGLE_CREDENTIALS_PATH=C:\path\to\credentials.json

# ============================================
# NOTAS
# ============================================

# 1. Variáveis vazias usam valores padrão seguros
# 2. Em produção, SEMPRE defina SECRET_KEY
# 3. Para APIs externas, configure pelo menos uma chave (GraphHopper ou OpenRouteService)
# 4. ENDERECO_FLORICULTURA é necessário para cálculo de distâncias
# 5. Veja docs/configuration.md para documentação completa
