# Backend - Variáveis de ambiente
# Copie para .env e ajuste os valores

# === Produção (obrigatórias) ===
FLASK_ENV=production
APP_ENV=production
SECRET_KEY=gerar-com-python-c-import-secrets-print-secrets-token-hex-32
ADMIN_PASSWORD=senha_forte_aqui

# === Banco de dados ===
# PostgreSQL (VPS): use DATABASE_URL
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# SQLite (dev): padrão ~/var/lib/database/database.db
# SQLALCHEMY_DATABASE_URI=sqlite:///C:/path/to/database.db

# === Servidor ===
HOST=0.0.0.0
PORT=5000
USE_HTTPS=false

# === Frontend (opcional) ===
# Caminho absoluto para frontend_v2/dist quando diferente do padrão
#FRONTEND_DIST_PATH=/app/frontend_v2/dist

# === APIs (opcionais) ===
#ENDERECO_FLORICULTURA=Rua Exemplo, 123, Bairro, Cidade, Estado, CEP
#GRAPHHOPPER_API_KEY=
#OPENROUTE_API_KEY=

# === Backup ===
#GDRIVE_BACKUP_DIR=/var/backups/gestor-pedidos
#BACKUP_SECONDARY_DIR=

# === Nuvemshop (integração / puxar pedidos) ===
# Na VPS use NUVEMSHOP_PUBLIC_BASE_URL com a URL pública (ex.: https://gestaopedidos.planteumaflor.online)
#NUVEMSHOP_APP_ID=
#NUVEMSHOP_CLIENT_SECRET=
#NUVEMSHOP_USER_AGENT=Gestor Pedidos (contato@seudominio.com)
#NUVEMSHOP_PUBLIC_BASE_URL=https://gestaopedidos.planteumaflor.online

# === Segurança ===
ENABLE_DEBUG_ENDPOINTS=false
