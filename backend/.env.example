# Plante Uma Flor - VariÃ¡veis de Ambiente
# Copie este arquivo para .env e configure os valores

# ============================================
# ConfiguraÃ§Ãµes do Servidor
# ============================================

# Ambiente Flask (development ou production)
FLASK_ENV=development

# Host do servidor (padrÃ£o: 0.0.0.0 para aceitar conexÃµes de qualquer IP)
HOST=0.0.0.0

# Porta do servidor (padrÃ£o: 5000)
PORT=5000

# Modo debug (True/False) - desativado por padrÃ£o para estabilidade
DEBUG=False

# Usar HTTPS ao iniciar (True/False)
USE_HTTPS=false

# Desativar reloader (True/False) - Ãºtil para modo estÃ¡vel
NO_RELOAD=false

# ForÃ§ar inÃ­cio mesmo se porta estiver em uso (True/False)
FORCE_START=false

# ============================================
# SeguranÃ§a
# ============================================

# Chave secreta para sessÃµes Flask (OBRIGATÃ“RIO em produÃ§Ã£o)
# Gere uma chave segura: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=plante-uma-flor-pwa-secret-key-2024

# Senha do administrador (para autenticaÃ§Ã£o)
ADMIN_PASSWORD=sua_senha_segura_aqui

# Habilitar autenticaÃ§Ã£o global (True/False)
# Se False, apenas rotas especÃ­ficas requerem autenticaÃ§Ã£o
ENABLE_AUTH=true

# Habilitar rate limiting (True/False)
ENABLE_RATE_LIMIT=true

# Habilitar endpoints de debug (True/False) - apenas em desenvolvimento
ENABLE_DEBUG_ENDPOINTS=false

# ============================================
# APIs Externas (Opcional)
# ============================================

# GraphHopper API Key (para cÃ¡lculo de rotas)
# Obtenha em: https://www.graphhopper.com/api/
# 500 requisiÃ§Ãµes/dia grÃ¡tis
GRAPHHOPPER_API_KEY=

# OpenRouteService API Key (backup para cÃ¡lculo de rotas)
# Obtenha em: https://openrouteservice.org/dev/#/signup
# 2000 requisiÃ§Ãµes/dia grÃ¡tis
OPENROUTE_API_KEY=

# EndereÃ§o da floricultura (para cÃ¡lculo de distÃ¢ncias)
# Formato: Rua, NÃºmero, Bairro, Cidade, Estado, CEP
# Exemplo: Rua Exemplo, 123, Bairro Centro, GoiÃ¢nia, GO, 74000-000
ENDERECO_FLORICULTURA=
