# Otimizações de performance para npm ci
# prefer-offline=true  # Removido: pode causar problemas se o cache não existir
audit=false
fund=false
# progress=false       # Removido: permite ver o progresso da instalação
loglevel=warn          # Mudado de error para warn: mostra avisos e progresso

# Cache otimizado
cache-max=86400000
fetch-retries=2
fetch-retry-mintimeout=20000
fetch-retry-maxtimeout=120000

# Registry (usar padrão do npm)
# registry=https://registry.npmjs.org/